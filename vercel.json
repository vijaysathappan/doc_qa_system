{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "app/**"
        ]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "app/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/documents/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/upload/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/query/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/logo.png",
      "dest": "frontend/logo.png"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
